# ============================================
# CBSE Vidyalaya - Environment Configuration
# ============================================

# --- LLM Providers ---
# Primary model for content generation (format: provider:model-name)
DEFAULT_MODEL=openai:gpt-4o

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODELS=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODELS=

# Google
GOOGLE_API_KEY=
GOOGLE_BASE_URL=
GOOGLE_MODELS=

# --- Text-to-Speech ---
# Supported: openai, azure, elevenlabs
TTS_PROVIDER=openai
OPENAI_TTS_API_KEY=
AZURE_TTS_API_KEY=
AZURE_TTS_REGION=

# --- Speech Recognition ---
ASR_PROVIDER=openai
OPENAI_ASR_API_KEY=

# --- Image Generation ---
IMAGE_PROVIDER=openai
IMAGE_API_KEY=

# --- Web Search ---
TAVILY_API_KEY=

# --- CBSE-Specific Settings ---
# Default language: en (English), hi (Hindi)
DEFAULT_LANGUAGE=en
# Default class level (1-12)
DEFAULT_CLASS=10
# Board: cbse, icse (future)
DEFAULT_BOARD=cbse
# Academic year
ACADEMIC_YEAR=2025-26

# --- Storage ---
# Storage provider: local, s3
STORAGE_PROVIDER=local
STORAGE_PATH=./data

# --- General ---
LOG_LEVEL=info
LOG_FORMAT=pretty
HTTP_PROXY=
HTTPS_PROXY=
